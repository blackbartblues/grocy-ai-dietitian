# Google Gemini API key (get at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Grocy instance URL (e.g. http://192.168.1.100:9283 or https://grocy.example.com)
GROCY_BASE_URL=http://your-grocy-host:port

# Grocy API key (found in Grocy → Manage API keys)
GROCY_API_KEY=your_grocy_api_key_here
